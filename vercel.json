{
  "buildCommand": "python manage.py collectstatic --noinput",
  "outputDirectory": "staticfiles",
  "functions": {
    "your_project_name/wsgi.py": {
      "runtime": "python3.12"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "bridal_app/wsgi.py"
    }
  ]
}